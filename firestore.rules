rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if a user is an admin
    function isAdmin(userId) {
      // Check for document existence before accessing data to prevent errors.
      return exists(/databases/$(database)/documents/Users/$(userId)) && 
             get(/databases/$(database)/documents/Users/$(userId)).data.isAdmin == true;
    }

    // Users can only read and write to their own document.
    // Admins can read and write to any user document.
    match /Users/{userId} {
      allow read, write: if request.auth.uid == userId || isAdmin(request.auth.uid);
    }

    // Authenticated users can read documents.
    // Admins can create, update, and delete documents.
    match /Documents/{documentId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin(request.auth.uid);
    }
    
    // This rule allows a user to create their own log entries.
    // An admin (by email) can read any log.
    // A non-admin user can only read their own log entries.
    match /Logs/{logId} {
      allow create: if request.auth.uid == request.resource.data.userId;
      allow read: if (request.auth.token.email == 'venicemarizene.linga@neu.edu.ph' && request.auth.token.email_verified) || 
                     request.auth.uid == resource.data.userId;
    }
  }
}
