rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the requesting user is an admin based on their verified email.
    function isRequestingUserAdmin() {
      return request.auth.token.email == 'venicemarizene.linga@neu.edu.ph' && request.auth.token.email_verified == true;
    }

    // Users can only read and write to their own document.
    // Admins can read and write to any user document.
    match /Users/{userId} {
      allow read, write: if request.auth.uid == userId || isRequestingUserAdmin();
    }

    // Authenticated users can read documents.
    // Admins can create, update, and delete documents.
    match /Documents/{documentId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isRequestingUserAdmin();
    }
    
    // This rule allows a user to create their own log entries.
    // An admin (by email) can read any log.
    // A non-admin user can only read their own log entries.
    match /Logs/{logId} {
      allow create: if request.auth.uid == request.resource.data.userId;

      // Any authenticated user can attempt a query on the logs collection.
      // The client-side query MUST be constrained to ensure users only request logs they have permission to read.
      allow list: if request.auth != null;

      // This rule secures the actual read of a single document.
      // It is enforced after the 'list' operation retrieves documents.
      allow get: if isRequestingUserAdmin() || request.auth.uid == resource.data.userId;
    }
  }
}
