rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the requesting user is an admin based on their verified email.
    function isRequestingUserAdmin() {
      return request.auth.token.email == 'venicemarizene.linga@neu.edu.ph' && request.auth.token.email_verified == true;
    }

    // Users can only read and write to their own document.
    // Admins can read and write to any user document.
    match /Users/{userId} {
      allow read, write: if request.auth.uid == userId || isRequestingUserAdmin();
    }

    // Authenticated users can read documents.
    // Admins can create, update, and delete documents.
    match /Documents/{documentId} {
      allow read: if request.auth != null;
      allow create, delete: if isRequestingUserAdmin();
      // Allow any authenticated user to increment the 'downloads' count.
      // Admins can update any field.
      allow update: if request.auth != null && 
                     (isRequestingUserAdmin() || 
                      (request.resource.data.downloads == resource.data.downloads + 1 &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['downloads'])));
    }
    
    match /Logs/{logId} {
      allow create: if request.auth.uid == request.resource.data.userId;
      // Only admins can read logs.
      allow read: if isRequestingUserAdmin();
    }
  }
}
